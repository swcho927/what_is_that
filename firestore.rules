// ⚠️ 이 파일은 참고용입니다. 실제 적용은 Firebase 콘솔 → Firestore Database → 규칙 에 붙여넣어야 합니다.
// (프로젝트: what-is-that-3cc48)
//
// 기존 users 규칙을 유지하면서 submissions 규칙을 추가한 형태입니다.
// 콘솔의 기존 규칙과 비교해 users 부분이 다르면 기존 것을 우선하고 submissions 블록만 추가하세요.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 유저 프로필 (랭킹/풀이 기록)
    match /users/{uid} {
      allow read: if true;                                   // 랭킹·프로필 공개 조회
      allow create, update: if request.auth != null
                            && request.auth.uid == uid;      // 본인만 작성/수정
      allow delete: if false;
    }

    // 제출 기록 (메타데이터 — 코드 제외, 공개)
    match /submissions/{subId} {
      allow read: if true;                                   // 모든 사람의 제출 현황 공개 조회
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;                        // 변경 불가

      // 제출 코드 (서브문서) — "그 문제를 푼 사람만" 읽기 허용
      match /private/{d} {
        allow read: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid))
                         .data.get('solvedProblems', [])
                         .hasAny([resource.data.problemId]);
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.uid
                      && request.resource.data.code.size() <= 20000;  // 코드 길이 제한
        allow update, delete: if false;
      }
    }

    // 최초 해결(퍼스트) — 문제당 1개, 처음 푼 사람만 생성
    match /firstSolves/{probId} {
      allow read: if true;                                   // 모두에게 알림 표시
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;                        // 최초 1명만, 변경 불가
    }
  }
}
